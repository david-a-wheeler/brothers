#!/usr/bin/env python3
"""Tiny threaded static file server for local development.

Supports multiple simultaneous requests, necessary for local development
(e.g., where there are many ES modules loading in parallel).
It also provides adequate security for local testing.

By default it serves to IP address 0.0.0.0 on port 8000
so you can access it on local network. You can provide on the command line
[IP_ADDRESS [PORT]] e.g., `127.0.01 8080`.

Many times you need a local web server for testing. E.g., if you use
JavaScript with ES modules, they *cannot* be loaded from file:
so you *must* run a webserver.

You can run a server using `python3 -m http.server 8000`
but this is a terrible idea. It can't handle multiple simultaneous
requests, and environments like JavaScript with modules & assets *require*
suport of many simultaneous requests. Also, if attackers get access
to the server, they can retrieve anything on the filesystem that the
webserver can see.

Security goal: We are primarily worried about *external* systems
that somehow can see and send commands to the server. We want our
local systems (same system, or same LAN) to gain quick access.

Threat model: We're primarily worried external systems making requests,
so we require a password for any access other than the password page.
We also want to ensure that (1) if an attacker can gain access to the
server's pages they can't discover the password (so .password must be
stored with an iterated salted hash), and (2) if they *can* get in,
they can only see the current directory and below. As extra protection,
we prevent downloading certain basename filename, especially `.password`.

We're NOT worried about storing passwords in the clear in the clients.
We aren't worried about transmitting passwords in the clear
(it's supposed to be the same system or a trusted/likely virtual LAN).
We're not worried about having passwords as cleartext
in server memory while the server is running; if the attacker has that
access we're doomed anyway since the attacker can watch what the client sends.

The encrypted password is stored in ".password"; delete that at any time to
force its regeneration. Passwords expire after a year, to limit damage,
and are auto-regenerated.
"""

import hashlib
import os
import secrets
import string
import sys
import threading
import time
from http.cookies import SimpleCookie
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import parse_qs

PASSWORD_FILE = ".password"
ONE_YEAR_SECONDS = 31536000  # 60 * 60 * 24 * 365

# Global runtime containers for the authentication data
STORED_HASH = None
STORED_SALT = None

# Unencrypted password sent by user, stored *in memory*.
# Our goal is to prevent *storing* the unencrypted password in *our*
# filesystem. If the attacker can see our memory we're doomed anyway.
# Note that the requester also has the unencrypted password & sends it
# unencrypted over the network.
CACHED_PASSWORD = None

# Prevents parallel thundering herd on server restart, by forcing
# requests to the password cache to occur one-at-a-time
CACHE_LOCK = threading.Lock()

def init_authentication():
    """Manages the password lifecycle.

    Loads existing hashes securely, checks for 1-year expiration,
    or generates a new password and prints it strictly ONCE.
    """
    global STORED_HASH, STORED_SALT

    if os.path.exists(PASSWORD_FILE):
        try:
            with open(PASSWORD_FILE, "r", encoding="utf-8") as f:
                parts = f.read().strip().split("|")

            if len(parts) == 3:
                timestamp = float(parts[0])
                STORED_SALT = bytes.fromhex(parts[1])
                STORED_HASH = bytes.fromhex(parts[2])

                # Check if the 1-year mark has passed since creation
                if time.time() - timestamp > ONE_YEAR_SECONDS:
                    print("\n" + "!" * 70)
                    print(" BIG WARNING: THE 1-YEAR COOKIE EXPIRATION LIFECYCLE HAS MET INDICES.")
                    print(" THE LOCAL ENCRYPTED PASSWORD HAS EXPIRED AND WILL NOW REGENERATE.")
                    print("!" * 70 + "\n")
                    # Break out to trigger a brand new password generation sequence
                else:
                    print("[Security] Loaded encrypted password hash from disk. Session is active.")
                    print("Delete file .password to regenerate a password.")
                    return
        except Exception as e:
            print(f"[Security Warning] Error reading password metadata ({e}). Resetting...")

    # Generate a fresh 12-character password
    alphabet = string.ascii_letters + string.digits # + "!@#$%^&*()-_=+[]{}|:"
    password = "".join(secrets.choice(alphabet) for _ in range(12))

    # BIG NOTE: Print out prominently on local console because this is the ONLY time it's visible
    print("=" * 70)
    print(" 🔑 A NEW WEB SERVER PASSWORD HAS BEEN GENERATED 🔑")
    print(f" PASSWORD: {password}")
    print("=" * 70)
    print(" NOTE: This password is now securely encrypted on disk.")
    print(" It will NEVER be printed on screen again upon server restarts.")
    print(" It will automatically expire and regenerate in one year.")
    print(" Erase the .password file to force re-generation of a password.")
    print("=" * 70)

    # Hash the password securely with PBKDF2, SHA-256, with iterations.
    STORED_SALT = secrets.token_bytes(16)
    STORED_HASH = compute_password_hash(password)

    # Save the creation timestamp, the salt, and the final hash to disk
    with open(PASSWORD_FILE, "w", encoding="utf-8") as f:
        f.write(f"{time.time()}|{STORED_SALT.hex()}|{STORED_HASH.hex()}")

def compute_password_hash(password):
    return hashlib.pbkdf2_hmac('sha256', password.encode('utf-8'), STORED_SALT, 100000)

def verify_password(plain_password):
    """Hashes the incoming client password text and checks it against the disk hash."""
    if not STORED_HASH or not STORED_SALT:
        return False

    # Hash the input using the exact same salt and iteration parameters
    test_hash = compute_password_hash(plain_password)

    # Constant-time comparison to prevent timing-attack side channels.
    return secrets.compare_digest(STORED_HASH, test_hash)

def verify_password_cached(plain_password):
    """Checks memory cache first; falls back to using PBKDF2 if cache is empty.

    Uses a thread lock to prevent a 'thundering herd' CPU bottleneck when multiple
    parallel ES module requests hit a newly restarted server simultaneously.
    """
    global CACHED_PASSWORD

    if not plain_password:
        return False

    # 1. Fast Path: Plaintext comparison against memorized runtime password
    if CACHED_PASSWORD and secrets.compare_digest(plain_password, CACHED_PASSWORD):
        return True

    # 2. Slow Path: Lock threads so only one thread runs the heavy PBKDF2 calculation
    with CACHE_LOCK:
        # Double-check inside the lock in case a parallel thread just filled the cache
        if CACHED_PASSWORD and secrets.compare_digest(plain_password, CACHED_PASSWORD):
            return True

        if verify_password(plain_password):
            CACHED_PASSWORD = plain_password  # Memorize for all future requests
            return True

    return False

class Handler(SimpleHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    extensions_map = {
        **SimpleHTTPRequestHandler.extensions_map,
        ".js": "text/javascript",
        ".mjs": "text/javascript",
        ".ico": "image/x-icon",
        ".svg": "image/svg+xml",
        ".tmj": "application/json",
    }

    def is_authenticated(self):
        """Checks if the browser's cookie password matches the possibly-locally-cached password."""

        cookie_header = self.headers.get("Cookie")
        if cookie_header:
            cookie = SimpleCookie(cookie_header)
            if "password" in cookie:
                return verify_password_cached(cookie["password"].value)
        return False

    def serve_login_form(self, error=False):
        """Serves a minimalist password entry prompt."""
        html = f"""<!DOCTYPE html>
<html>
<head>
    <title>Server Authentication</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body {{ font-family: sans-serif; margin: 2rem; background: #f9f9f9; }}
        .box {{ max-width: 400px; margin: 5rem auto; padding: 2rem; background: #fff; border: 1px solid #ccc; border-radius: 5px; }}
        input[type="password"] {{ width: 100%; padding: 0.5rem; margin: 1rem 0; box-sizing: border-box; }}
        input[type="submit"] {{ width: 100%; padding: 0.5rem; background: #28a745; color: white; border: none; border-radius: 3px; cursor: pointer; }}
        .error {{ color: #dc3545; margin-bottom: 1rem; font-weight: bold; }}
    </style>
</head>
<body>
    <div class="box">
        <h2>Authentication Required</h2>
        { '<p class="error">Invalid password. Please try again.</p>' if error else '' }
        <form method="POST" action="/login">
            <label>Password: <input type="password" name="password" required autofocus></label>
            <input type="submit" value="Unlock Server">
        </form>
    </div>
</body>
</html>"""
        body = html.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self):
        """Handles password payload processing."""
        if self.path == "/login":
            content_length = int(self.headers.get('Content-Length', 0))
            post_data = self.rfile.read(content_length).decode('utf-8')
            params = parse_qs(post_data)
            submitted_password = params.get('password', [''])[0]

            if verify_password_cached(submitted_password):
                self.send_response(303)
                self.send_header("Location", "/")
                # Explicitly zero-out body as required by spec,
                # to prevent Firefox hang
                self.send_header("Content-Length", "0")
                # Force Max-Age attribute to equal exactly 1 year in seconds
                self.send_header(
                    "Set-Cookie",
                    f"password={submitted_password}; Path=/; HttpOnly; SameSite=Strict; Max-Age={ONE_YEAR_SECONDS}"
                )
                self.end_headers()
            else:
                self.serve_login_form(error=True)
        else:
            self.send_error(404, "Not Found")

    def end_headers(self):
        self.send_header("Cache-Control", "no-store")
        self.send_header("X-Content-Type-Options", "nosniff")
        super().end_headers()

    def is_sensitive_file(self, filename):
        """Determines if a file basename looks like a sensitive credential or config file."""
        filename_lower = filename.lower()

        # 1. Exact matches for common local development or system files
        blocked_names = {
            ".password", ".netrc", ".env",
            ".bash_history", ".zsh_history", ".ds_store"
        }
        if filename_lower in blocked_names:
            return True

        # 2. Block SSH private keys (typically start with 'id_' and don't end in '.pub')
        if filename_lower.startswith("id_") and not filename_lower.endswith(".pub"):
            return True

        # 3. Block common crypto private key/certificate extensions
        blocked_extensions = (".pem", ".key", ".pfx", ".p12", ".pkcs12")
        if filename_lower.endswith(blocked_extensions):
            return True

        return False

    def send_head(self):
        """Validates network boundary mechanics and cryptographic state, sends if okay."""
        if not self.is_authenticated():
            self.serve_login_form()
            return None

        target_path = self.translate_path(self.path)
        base_dir = os.path.realpath(os.getcwd())
        abs_target = os.path.realpath(target_path)

        try:
            if os.path.commonpath([base_dir, abs_target]) != base_dir:
                self.send_error(403, "Forbidden: Access outside root directory is denied.")
                return None
        except ValueError:
            self.send_error(403, "Forbidden")
            return None

        # SENSITIVE FILE FILTER ---
        # Extract just the final filename
        # (e.g., "/src/.password" becomes ".password")
        # and refuse to serve it if it appears sensitive.
        basename = os.path.basename(abs_target)
        if self.is_sensitive_file(basename):
            self.send_error(403, "Forbidden: Access to sensitive configuration or credential files is denied.")
            return None
        # ----------------------------------

        return super().send_head()

class SecureThreadingHTTPServer(ThreadingHTTPServer):
    request_queue_size = 64


def main():
    bind_address = "0.0.0.0"
    port = 8000

    if len(sys.argv) > 1:
        if sys.argv[1].isdigit():
            port = int(sys.argv[1])
        else:
            bind_address = sys.argv[1]
            if len(sys.argv) > 2 and sys.argv[2].isdigit():
                port = int(sys.argv[2])

    # Spin up cryptographic verification data maps
    init_authentication()

    httpd = SecureThreadingHTTPServer((bind_address, port), Handler)
    print(f"Serving http://{bind_address}:{port}/  (Ctrl+C to stop)")

    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print()
    finally:
        httpd.server_close()


if __name__ == "__main__":
    main()
