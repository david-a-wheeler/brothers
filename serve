#!/usr/bin/env python3
"""Tiny threaded static file server (unencrypted) for local development.

Optimized for modern frontend development (parallel ES module loading)
with strict local security boundaries. This can handle many
simultaneous requests without keeling over, which is important
for loading JavaScript and various assets.

===============================================================================
NETWORK & SECURITY CONFIGURATION DOCS
===============================================================================

1. FINDING YOUR VM'S IP ADDRESS
   Run one of the following commands inside your VM terminal:
   - Linux/macOS:  ip addr  OR  ifconfig
   - Windows:      ipconfig
   Look for the interface linked to your virtual network (e.g., eth1, enp0s8).
   It usually looks like 192.168.X.X, 10.X.X.X, or 172.16.X.X.

2. RUNNING THE SERVER
   By default, it binds to 127.0.0.1 (localhost) for safety.
   To expose it ONLY to your virtual local network, pass the VM's local IP:

   Usage:
     ./serve [bind_address] [port]

   Examples:
     ./serve 192.168.56.101       # Listens on VM IP, default port 8000
     ./serve 192.168.56.101 9000  # Listens on VM IP, custom port 9000

3. HARDENING ACCESS via FIREWALL (Highly Recommended)
   Even when bound to a specific IP, anyone on that virtual network can connect.
   Use a firewall to restrict access to a SINGLE trusted client machine.
   (Assuming VM IP is 192.168.56.101 and Client IP is 192.168.56.105)

   Linux (UFW):
     sudo ufw deny 8000/tcp
     sudo ufw allow from 192.168.56.105 to any port 8000 proto tcp
     sudo ufw enable

   Windows Defender Firewall:
     1. Open "Windows Defender Firewall with Advanced Security".
     2. Create a new "Inbound Rule" -> Choose "Port" -> TCP -> Specific local ports: 8000.
     3. Choose "Allow the connection".
     4. Name the rule, then right-click the created rule -> Properties -> Scope tab.
     5. Under "Remote IP address", select "These IP addresses" -> Add "192.168.56.105".
===============================================================================
"""

import os
import sys
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer


class Handler(SimpleHTTPRequestHandler):
    # Use HTTP/1.1 to enable Keep-Alive. This allows connection reuse
    # and completely eliminates net::ERR_SOCKET_NOT_CONNECTED on heavy reloads.
    protocol_version = "HTTP/1.1"

    extensions_map = {
        **SimpleHTTPRequestHandler.extensions_map,
        ".js": "text/javascript",
        ".mjs": "text/javascript",
        ".ico": "image/x-icon",
        ".svg": "image/svg+xml",
        ".tmj": "application/json",
    }

    def end_headers(self):
        self.send_header("Cache-Control", "no-store")
        # Security Bonus: Prevents browsers from guessing/riding MIME types
        self.send_header("X-Content-Type-Options", "nosniff")
        super().end_headers()

    def send_head(self):
        """Intercepts requests to strictly enforce directory boundaries."""
        # Get the path the standard implementation wants to serve
        target_path = self.translate_path(self.path)

        # Resolve all relative paths and symlinks to absolute paths
        base_dir = os.path.realpath(os.getcwd())
        abs_target = os.path.realpath(target_path)

        # Bulletproof Directory Traversal Guard (handles symlinks safely)
        try:
            # os.path.commonpath guarantees abs_target is structurally inside base_dir
            if os.path.commonpath([base_dir, abs_target]) != base_dir:
                self.send_error(403, "Forbidden: Access outside root directory is denied.")
                return None
        except ValueError:
            self.send_error(403, "Forbidden")
            return None

        return super().send_head()


class SecureThreadingHTTPServer(ThreadingHTTPServer):
    # Increase the OS connection backlog queue from 5 to 64.
    # This absorbs massive parallel request spikes smoothly.
    request_queue_size = 64


def main():
    bind_address = "127.0.0.1"
    port = 8000

    # Parse command line args dynamic configuration
    if len(sys.argv) > 1:
        if sys.argv[1].isdigit():
            port = int(sys.argv[1])
        else:
            bind_address = sys.argv[1]
            if len(sys.argv) > 2 and sys.argv[2].isdigit():
                port = int(sys.argv[2])

    httpd = SecureThreadingHTTPServer((bind_address, port), Handler)

    print(f"Serving http://{bind_address}:{port}/  (Ctrl+C to stop)")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print()
    finally:
        httpd.server_close()


if __name__ == "__main__":
    main()
